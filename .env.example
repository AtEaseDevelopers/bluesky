APP_NAME="Bluesky Live Seafood"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=oms

# PHPUnit uses oms_test (see phpunit.xml) so "php artisan test" does not wipe dev data.
# Create once: mysql -e "CREATE DATABASE IF NOT EXISTS oms_test;"
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

PORTAL_COMPANY_NAME="${APP_NAME}"
PORTAL_COMPANY_REG=1130071.K
PORTAL_COMPANY_PHONE=
PORTAL_COMPANY_EMAIL=
PORTAL_COMPANY_ADDRESS="Jln 11, Kampung Baru Ampang, 68000 Ampang, Selangor."

# AutoCount plugin integration (BlueskyPlugin polls these endpoints)
AUTOCOUNT_API_TOKEN=
AUTOCOUNT_BRANCH_EMAIL="${PORTAL_COMPANY_EMAIL}"
# AutoCount debtor AccNo for walk-in / general link / POS guest orders (no customer account)
AUTOCOUNT_WALK_IN_DEBTOR_CODE=
# Optional overrides; default to AUTOCOUNT_WALK_IN_DEBTOR_CODE when empty
# AUTOCOUNT_PUBLIC_ORDER_DEBTOR_CODE=
# AUTOCOUNT_POS_GUEST_DEBTOR_CODE=
# Production site: https://bslseafoodsupply.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Revenue Monster (payment QR)
# IMPORTANT: RM redirects the customer and calls the payment webhook using
# APP_URL. It must be a PUBLIC, internet-reachable URL (not http://127.0.0.1 /
# localhost) or real devices can't return and RM's callback can't reach you —
# use a tunnel (e.g. ngrok) or your deployed domain.
RM_SANDBOX=true
RM_CLIENT_ID=
RM_CLIENT_SECRET=
RM_PRIVATE_KEY_PATH=
RM_PUBLIC_KEY_PATH=
RM_STORE_ID=
# Only ACTIVE DuitNow/e-wallet codes (RM 403s the whole request if any is
# inactive). Leave empty to show every active method. Excludes FPX by listing.
RM_METHODS=TNG_MY
# Public return page after payment (defaults to /payment/return if empty).
RM_REDIRECT_URL=
RM_MIN_AMOUNT=1
